# Copy to .env and fill in real values. Never commit .env.

# MySQL connection string. For local dev via XAMPP: mysql://root@localhost:3306/sportpark
# For production, point this at a properly hosted MySQL instance (VPS, PlanetScale, RDS, etc.).
DATABASE_URL="mysql://root@localhost:3306/sportpark"

# AES-256-GCM key for encrypting registrant phone numbers at rest. Must decode to exactly 32 bytes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# Exact origin this app is served from (scheme + host + port). Used for CSRF origin checks.
APP_ORIGIN="http://localhost:5173"

NODE_ENV="development"
