generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  sessions     Session[]

  @@map("admins")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([adminId])
  @@map("sessions")
}

model Event {
  id                   String         @id @default(cuid())
  title                String
  titleRu              String?
  category             String
  description          String         @db.Text
  descriptionRu        String?        @db.Text
  date                 String // YYYY-MM-DD
  startTime            String // HH:mm
  endTime              String // HH:mm
  location             String
  coach                String?
  maxRegistrations     Int
  bannerImage          String?        @db.Text
  registrationDeadline DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?
  registrations        Registration[]

  @@index([date])
  @@index([deletedAt])
  @@map("events")
}

model Registration {
  id          String    @id @default(cuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id])
  token       String    @unique
  name        String
  phone       String?   @db.Text // AES-256-GCM ciphertext, base64
  visitorId   String? // opaque per-browser cookie id, scopes the one-registration-per-browser rule
  createdAt   DateTime  @default(now())
  cancelledAt DateTime?

  @@index([eventId])
  @@index([eventId, visitorId])
  @@map("registrations")
}
